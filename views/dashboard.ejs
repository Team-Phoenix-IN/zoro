<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Zoro V3 Dashboard — Manage your Discord servers">
  <title>Dashboard | <%= user.username %> — Zoro V3</title>
  <link rel="shortcut icon" href="/images/phoenix-logo.png" type="image/png">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

<!-- Mobile overlay -->
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<!-- Mobile sidebar toggle -->
<button class="sidebar-toggle" id="sidebar-toggle" aria-label="Open sidebar">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <line x1="3" y1="12" x2="21" y2="12"/>
    <line x1="3" y1="6" x2="21" y2="6"/>
    <line x1="3" y1="18" x2="21" y2="18"/>
  </svg>
</button>

<div class="dash-layout">

  <!-- ======== SIDEBAR ======== -->
  <aside class="dash-sidebar" id="dash-sidebar">

    <!-- Brand -->
    <div class="sidebar-brand">
      <img src="/images/phoenix-logo.png" alt="Team Phoenix">
      <div class="sidebar-brand-text">
        <span class="sidebar-brand-name">ZORO V3</span>
        <span class="sidebar-brand-tag">Team Phoenix</span>
      </div>
    </div>

    <!-- User block -->
    <div class="sidebar-user">
      <img
        src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=128"
        alt="<%= user.username %>"
        class="sidebar-avatar"
        onerror="this.src='/images/phoenix-logo.png'"
      >
      <div class="sidebar-user-info">
        <div class="sidebar-username"><%= user.username %></div>
        <div class="sidebar-discriminator">#<%= user.discriminator %></div>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="sidebar-nav">
      <div class="sidebar-nav-label">Navigation</div>

      <a href="/dashboard" class="nav-item active" id="nav-servers">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        My Servers
      </a>

      <a href="/" class="nav-item" id="nav-home">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Home
      </a>

      <div class="sidebar-nav-label" style="margin-top:12px;">Support</div>

      <a href="https://discord.gg/your-server" target="_blank" class="nav-item" id="nav-support">
        <!-- Discord Clyde icon -->
        <svg viewBox="0 0 127.14 96.36" fill="currentColor" xmlns="http://www.w3.org/2000/svg" style="width:18px;height:18px;flex-shrink:0;color:#7289da;">
          <path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/>
        </svg>
        Discord Server
      </a>
    </nav>

    <!-- Logout -->
    <div class="sidebar-bottom">
      <a href="/logout" class="btn-logout" id="btn-logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Logout
      </a>
    </div>
  </aside>

  <!-- ======== MAIN ======== -->
  <main class="dash-main">

    <!-- Top Bar -->
    <header class="dash-topbar">
      <div>
        <div class="topbar-title">Dashboard</div>
        <div class="topbar-subtitle">Manage your Discord servers</div>
      </div>
      <div class="topbar-badge">
        <span class="status-dot"></span>
        Bot Online
      </div>
    </header>

    <!-- Content -->
    <div class="dash-content">

      <!-- Welcome Banner -->
      <div class="welcome-banner">
        <img
          src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=256"
          alt="<%= user.username %>"
          class="welcome-avatar"
          onerror="this.src='/images/phoenix-logo.png'"
        >
        <div class="welcome-text">
          <h2>Welcome back, <span><%= user.username %></span>!</h2>
          <p>Select a server below to manage your bot settings and preferences.</p>
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <div class="stat-card-value"><%= guilds.length %></div>
          <div class="stat-card-label">Your Servers</div>
        </div>

        <div class="stat-card">
          <div class="stat-card-icon" style="background:rgba(87,242,135,0.1);">
            <svg viewBox="0 0 24 24" fill="none" stroke="#57f287" stroke-width="2">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div class="stat-card-value" style="color:#57f287;"><%= guilds.filter(g => g.hasBot).length %></div>
          <div class="stat-card-label">Bot Active</div>
        </div>

        <div class="stat-card">
          <div class="stat-card-icon" style="background:rgba(254,231,92,0.1);">
            <svg viewBox="0 0 24 24" fill="none" stroke="#fee75c" stroke-width="2">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </div>
          <div class="stat-card-value" style="color:#fee75c;">11</div>
          <div class="stat-card-label">Commands</div>
        </div>

        <div class="stat-card">
          <div class="stat-card-icon" style="background:rgba(88,101,242,0.15);">
            <svg viewBox="0 0 24 24" fill="none" stroke="#5865f2" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="stat-card-value" style="color:#5865f2;">24/7</div>
          <div class="stat-card-label">Uptime</div>
        </div>
      </div>

      <!-- Guilds Section -->
      <div class="section-header">
        <div class="section-title">Your Servers</div>
        <div class="section-count"><%= guilds.length %> servers</div>
      </div>

      <div class="guilds-grid" id="guilds-grid">

        <% if (guilds.length === 0) { %>
        <div class="empty-state">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
          <p>No servers found where you have Manage Server permissions.</p>
        </div>
        <% } %>

        <% guilds.forEach((guild, i) => { %>
        <div class="guild-card" style="--anim-delay: <%= i * 0.06 %>s"
          data-id="<%= guild.id %>"
          data-name="<%= encodeURIComponent(guild.name) %>"
          data-icon="<%= guild.icon %>"
          data-bot="<%= guild.hasBot %>"
          onclick="openServerPanel(this.dataset.id, decodeURIComponent(this.dataset.name), this.dataset.icon, this.dataset.bot)">

          <!-- Top Row: Icon + Name + Status -->
          <div class="guild-card-top">
            <div class="guild-icon">
              <% if (guild.icon) { %>
                <img
                  src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png?size=128"
                  alt="<%= guild.name %>"
                  onerror="this.parentElement.innerHTML='<%= guild.name.charAt(0) %>'"
                >
              <% } else { %>
                <%= guild.name.charAt(0).toUpperCase() %>
              <% } %>
            </div>

            <div class="guild-info">
              <div class="guild-name" title="<%= guild.name %>"><%= guild.name %></div>
              <% if (guild.hasBot) { %>
                <div class="guild-status has-bot">
                  <span class="guild-status-dot"></span>
                  Bot Active
                </div>
              <% } else { %>
                <div class="guild-status no-bot">
                  <span class="guild-status-dot"></span>
                  Bot Not Added
                </div>
              <% } %>
            </div>
          </div>

          <div class="guild-divider"></div>

          <!-- Automod Toggle -->
          <div class="toggle-row">
            <div class="toggle-label-group">
              <div class="toggle-label">Auto Moderation</div>
              <div class="toggle-desc">Auto-delete rule-breaking messages</div>
            </div>

            <label class="toggle-switch">
              <input
                type="checkbox"
                id="automod-<%= guild.id %>"
                <%= guild.automodEnabled ? 'checked' : '' %>
                <%= !guild.hasBot ? 'disabled' : '' %>
                onchange="toggleAutomod('<%= guild.id %>', this.checked)"
              >
              <span class="toggle-track"></span>
            </label>
          </div>

          <% if (!guild.hasBot) { %>
          <div style="text-align:center;">
            <a
              href="https://discord.com/oauth2/authorize?client_id=<%= process.env.DISCORD_CLIENT_ID || '0' %>&permissions=8&scope=bot%20applications.commands&guild_id=<%= guild.id %>"
              target="_blank"
              style="display:inline-block; font-size:12px; color:#5865f2; text-decoration:underline; margin-top:-4px;"
            >
              + Add Zoro to this server
            </a>
          </div>
          <% } %>

        </div>
        <% }); %>
      </div>

    </div><!-- /.dash-content -->
  </main>

</div><!-- /.dash-layout -->

<!-- Server Settings Panel -->
<div class="panel-overlay" id="panel-overlay" onclick="closeServerPanel()"></div>
<aside class="server-panel" id="server-panel">
  <div class="sp-header">
    <div class="sp-guild-info">
      <div class="sp-guild-icon" id="sp-guild-icon"></div>
      <div>
        <div class="sp-guild-name" id="sp-guild-name">Server</div>
        <div class="sp-guild-id" id="sp-guild-id"></div>
      </div>
    </div>
    <button class="sp-close" onclick="closeServerPanel()" aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <!-- Inner: vertical nav + content -->
  <div class="sp-inner">

    <!-- Vertical Nav -->
    <nav class="sp-tabs">

      <div class="sp-nav-group-label">General</div>
      <button class="sp-tab active" data-tab="commands" onclick="switchTab('commands')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        <span>Commands</span>
      </button>
      <button class="sp-tab" data-tab="automod" onclick="switchTab('automod')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>Auto Mod</span>
      </button>
      <button class="sp-tab" data-tab="wordfilter" onclick="switchTab('wordfilter')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        <span>Word Filter</span>
      </button>
      <button class="sp-tab" data-tab="warnings" onclick="switchTab('warnings')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span>Warnings</span>
      </button>

      <div class="sp-nav-group-label">Features</div>
      <button class="sp-tab" data-tab="welcome" onclick="switchTab('welcome')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span>Welcome</span>
      </button>
      <button class="sp-tab" data-tab="leveling" onclick="switchTab('leveling')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        <span>Leveling</span>
      </button>
      <button class="sp-tab" data-tab="verification" onclick="switchTab('verification')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span>Verification</span>
      </button>
      <button class="sp-tab" data-tab="tickets" onclick="switchTab('tickets')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/></svg>
        <span>Tickets</span>
      </button>
      <button class="sp-tab" data-tab="suggestions" onclick="switchTab('suggestions')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        <span>Suggestions</span>
      </button>
      <button class="sp-tab" data-tab="birthdays" onclick="switchTab('birthdays')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span>Birthdays</span>
      </button>
      <button class="sp-tab" data-tab="voice" onclick="switchTab('voice')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
        <span>Voice Setup</span>
      </button>

      <div class="sp-nav-group-label">Content</div>
      <button class="sp-tab" data-tab="autoresponder" onclick="switchTab('autoresponder')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
        <span>Auto Responders</span>
      </button>
      <button class="sp-tab" data-tab="stickymessages" onclick="switchTab('stickymessages')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
        <span>Sticky Messages</span>
      </button>
      <button class="sp-tab" data-tab="buttonroles" onclick="switchTab('buttonroles')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <span>Button Roles</span>
      </button>
      <button class="sp-tab" data-tab="announcer" onclick="switchTab('announcer')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg>
        <span>Announcer</span>
      </button>

      <div class="sp-nav-group-label">Economy</div>
      <button class="sp-tab" data-tab="economyshop" onclick="switchTab('economyshop')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        <span>Economy Shop</span>
      </button>

      <div class="sp-nav-group-label">Server</div>
      <button class="sp-tab" data-tab="serverstats" onclick="switchTab('serverstats')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        <span>Server Stats</span>
      </button>
    </nav>

    <!-- Content Panes -->
    <div class="sp-body">
    <!-- Commands Tab -->
    <div class="sp-pane active" id="tab-commands">
      <div class="sp-notice" id="cmd-no-bot" style="display:none">⚠️ Add the bot to this server to enable/disable commands.</div>
      
      <div class="sp-field-group" style="background:var(--bg-lighter); padding:15px; border-radius:8px; margin-bottom:20px;">
        <label class="sp-field-label" for="cmd-prefix">Custom Prefix</label>
        <div class="sp-field-desc" style="margin-bottom:8px;">The bot mainly uses <strong>Slash Commands (/)</strong>. If users type the custom prefix (e.g. <code>!help</code>), the bot will remind them to use slash commands.</div>
        <input class="sp-input" id="cmd-prefix" type="text" placeholder="e.g. !" maxlength="5">
      </div>

      <div class="sp-field-label">Command Modules</div>
      <div class="sp-field-desc" style="margin-bottom:10px;">Toggle which commands are allowed in your server.</div>
      <div id="commands-list"></div>
      <button class="sp-save-btn" id="cmd-save-btn" onclick="saveCommands()">Save Changes</button>
    </div>
    <!-- Auto Mod Tab -->
    <div class="sp-pane" id="tab-automod">
      <div class="sp-notice" id="am-no-bot" style="display:none">⚠️ Add the bot to this server first.</div>

      <!-- Toggle row -->
      <div class="sp-field-group">
        <div class="sp-toggle-row">
          <div>
            <div class="sp-field-label">Auto Moderation</div>
            <div class="sp-field-desc">Automatically delete rule-breaking messages.</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="am-toggle" onchange="saveAutomod()">
            <span class="toggle-track"></span>
          </label>
        </div>
      </div>

      <!-- Log channel -->
      <div class="sp-field-group">
        <label class="sp-field-label" for="am-log">Log Channel ID</label>
        <div class="sp-field-desc">Paste the channel snowflake ID where mod logs will appear.</div>
        <input class="sp-input" id="am-log" type="text" placeholder="e.g. 123456789012345678">
      </div>
      <button class="sp-save-btn" onclick="saveAutomodLog()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;display:inline;vertical-align:middle;margin-right:6px"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        Save Log Channel
      </button>
    </div>
    <!-- Verification Tab -->
    <div class="sp-pane" id="tab-verification">
      <div class="sp-notice" id="vf-no-bot" style="display:none">⚠️ Add the bot to this server first.</div>
      <p class="sp-desc-text">Set the channel and role for the verification system. Click <strong>Send Verification Embed</strong> to post the verify button in that channel.</p>

      <div class="sp-field-group">
        <label class="sp-field-label" for="vf-channel">Verification Channel ID</label>
        <div class="sp-field-desc">The channel where the verification embed will be posted.</div>
        <input class="sp-input" id="vf-channel" type="text" placeholder="e.g. 123456789012345678">
      </div>

      <div class="sp-field-group">
        <label class="sp-field-label" for="vf-role">Verified Role ID</label>
        <div class="sp-field-desc">The role assigned to users after they verify.</div>
        <input class="sp-input" id="vf-role" type="text" placeholder="e.g. 987654321098765432">
      </div>

      <div class="sp-vf-actions">
        <button class="sp-save-btn sp-save-btn--secondary" onclick="saveVerification(false)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;display:inline;vertical-align:middle;margin-right:6px"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Save Config Only
        </button>
        <button class="sp-save-btn" onclick="saveVerification(true)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;display:inline;vertical-align:middle;margin-right:6px"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg>
          Send Verification Embed
        </button>
      </div>
    </div>
    
    <!-- Welcome Tab -->
    <div class="sp-pane" id="tab-welcome">
