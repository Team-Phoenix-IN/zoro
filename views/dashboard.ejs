    document.getElementById('br-no-bot').style.display = _panelHasBot ? 'none' : 'block';
    ['br-channel','br-title','br-desc','br-btn-label','br-btn-role'].forEach(id => document.getElementById(id).disabled = !_panelHasBot);

    // ---- Word Filter ----
    document.getElementById('wf-no-bot').style.display = _panelHasBot ? 'none' : 'block';
    document.getElementById('wf-word').disabled        = !_panelHasBot;

    // ---- Server Stats ----
    document.getElementById('ss-no-bot').style.display = _panelHasBot ? 'none' : 'block';
    document.getElementById('ss-toggle').checked       = cfg.stats?.enabled || false;
    document.getElementById('ss-toggle').disabled      = !_panelHasBot;

