  // ---- Announcer ----
  async function sendAnnouncement() {
    const channelId = document.getElementById('ann-channel').value.trim();
    const title = document.getElementById('ann-title').value.trim();
    const description = document.getElementById('ann-desc').value.trim();
    const color = document.getElementById('ann-color').value.trim();
    const imageUrl = document.getElementById('ann-img').value.trim();

    if (!channelId || !title || !description) return showToast('Channel, Title, and Description required.', 'error');

    showToast('Dispatching announcement...', 'info');
    try {
      const r = await fetch(`/api/guilds/${_panelGuildId}/announcer/send`, {
        method:'POST', headers:{'Content-Type':'application/json'}, 
        body: JSON.stringify({ channelId, title, description, color, imageUrl })
      });
      
      if (r.ok) {
        showToast('Announcement sent to Discord! 🚀', 'success');
        document.getElementById('ann-channel').value = '';
        document.getElementById('ann-title').value = '';
        document.getElementById('ann-desc').value = '';
        document.getElementById('ann-color').value = '';
        document.getElementById('ann-img').value = '';
      } else {
        showToast('Failed to send. Check bot permissions.', 'error');
      }
    } catch(e) {
      showToast('Error processing request.', 'error');
    }
  }
