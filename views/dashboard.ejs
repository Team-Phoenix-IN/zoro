    document.getElementById('es-no-bot').style.display = _panelHasBot ? 'none' : 'block';
    ['es-name','es-desc','es-price','es-role'].forEach(id => document.getElementById(id).disabled = !_panelHasBot);

    // ---- Warnings ----
    document.getElementById('warn-no-bot').style.display = _panelHasBot ? 'none' : 'block';
    document.getElementById('warn-user-id').disabled = !_panelHasBot;

    // ---- Announcer ----
    document.getElementById('ann-no-bot').style.display = _panelHasBot ? 'none' : 'block';
