  async function saveCommands() {
    const toggles = document.querySelectorAll('.cmd-toggle');
    const disabled = [];
    toggles.forEach(t => { if (!t.checked) disabled.push(t.dataset.cmd); });
    
    const prefixInput = document.getElementById('cmd-prefix').value.trim() || '!';

    const btn = document.getElementById('cmd-save-btn');
    btn.disabled = true; btn.textContent = 'Saving…';
    try {
      const r = await fetch(`/api/guilds/${_panelGuildId}/commands`, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ disabledCommands: disabled, prefix: prefixInput })
      });
      const d = await r.json();
      if (r.ok) { _configCache[_panelGuildId] = null; showToast('Command settings saved!','success'); }
      else showToast(d.error||'Failed to save.','error');
    } catch(e) { showToast('Network error.','error'); }
    btn.disabled = false; btn.textContent = 'Save Changes';
  }

