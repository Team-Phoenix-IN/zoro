  // ---- Button Roles ----
  let _brDraftButtons = [];
  
  function addBtnRoleToDraft() {
    const label = document.getElementById('br-btn-label').value.trim();
    const roleId = document.getElementById('br-btn-role').value.trim();
    if (!label || !roleId) return showToast('Label and Role ID required.', 'error');
    if (_brDraftButtons.length >= 5) return showToast('Max 5 buttons per panel.', 'error');
    
    _brDraftButtons.push({ label, roleId, style: 1 });
    document.getElementById('br-btn-label').value = '';
    document.getElementById('br-btn-role').value = '';
    renderDraftButtons();
  }

  function renderDraftButtons() {
    const list = document.getElementById('br-draft-list');
    list.innerHTML = _brDraftButtons.map((btn, i) => `
      <span style="display:inline-block; background:var(--primary); color:white; padding:4px 8px; border-radius:4px; font-size:12px;">
        ${btn.label} <span style="cursor:pointer; margin-left:5px; font-weight:bold" onclick="_brDraftButtons.splice(${i},1); renderDraftButtons()">×</span>
      </span>
    `).join('');
  }

  async function saveAndSendButtonRole() {
    const channelId = document.getElementById('br-channel').value.trim();
    const title = document.getElementById('br-title').value.trim();
    const description = document.getElementById('br-desc').value.trim();
    
    if (!channelId || !_brDraftButtons.length) return showToast('Channel ID and at least 1 button required.', 'error');
    
    try {
      // 1. Save panel to DB
      const r1 = await fetch(`/api/guilds/${_panelGuildId}/buttonroles`, {
        method:'POST', headers:{'Content-Type':'application/json'}, 
        body: JSON.stringify({ channelId, title, description, buttons: _brDraftButtons })
      });
      
      if (!r1.ok) throw new Error('Failed to save panel to DB');
      const data = await r1.json();
      
      // 2. Trigger send to Discord
      showToast('Dispatching to Discord...', 'info');
      const r2 = await fetch(`/api/guilds/${_panelGuildId}/buttonroles/${data.panel._id}/send`, { method:'POST' });
      
      if (r2.ok) {
        showToast('Panel sent successfully!', 'success');
        _brDraftButtons = [];
        renderDraftButtons();
        document.getElementById('br-channel').value = '';
        loadButtonRoles();
      } else {
        showToast('Failed to send to Discord. Check Bot permissions.', 'error');
      }
    } catch(e) {
      showToast(e.message || 'Error processing request.', 'error');
    }
  }

