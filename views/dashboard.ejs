<!-- Toast container -->
<div class="toast-container" id="toast-container"></div>

<script>
  // ---- Mobile Sidebar ----
  const sidebar   = document.getElementById('dash-sidebar');
  const overlay   = document.getElementById('sidebar-overlay');
  const toggleBtn = document.getElementById('sidebar-toggle');

  function openSidebar() {
    sidebar.classList.add('open');
    overlay.classList.add('show');
  }

  function closeSidebar() {
    sidebar.classList.remove('open');
    overlay.classList.remove('show');
  }

  toggleBtn.addEventListener('click', openSidebar);
  overlay.addEventListener('click', closeSidebar);

  // ---- Toast ----
  function showToast(message, type = 'info') {
    const container = document.getElementById('toast-container');
    const icons = {
      success: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#57f287" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>`,
      error:   `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ed4245" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`,
      info:    `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5865f2" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`
    };

    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.innerHTML = `${icons[type] || icons.info}<span>${message}</span>`;
    container.appendChild(toast);

    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transform = 'translateX(20px)';
      toast.style.transition = 'all 0.3s ease';
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  }

  // ---- Server Panel State ----
  let _panelGuildId  = null;
  let _panelHasBot   = false;
  let _configCache   = {};   // guildId -> config
  let _disabled      = new Set();

  function openServerPanel(guildId, guildName, guildIcon, hasBot) {
    _panelGuildId = guildId;
    _panelHasBot  = hasBot === 'true' || hasBot === true;

    // Header
    document.getElementById('sp-guild-name').textContent = guildName;
    document.getElementById('sp-guild-id').textContent   = 'ID: ' + guildId;
    const iconEl = document.getElementById('sp-guild-icon');
    if (guildIcon && guildIcon !== 'null') {
      iconEl.innerHTML = `<img src="https://cdn.discordapp.com/icons/${guildId}/${guildIcon}.png?size=64" onerror="this.parentElement.textContent='${guildName.charAt(0)}'">`;
    } else {
      iconEl.textContent = guildName.charAt(0).toUpperCase();
    }

    switchTab('commands');
    document.getElementById('server-panel').classList.add('open');
    document.getElementById('panel-overlay').classList.add('show');
    document.body.style.overflow = 'hidden';
    loadGuildConfig(guildId);
  }

  function closeServerPanel() {
    document.getElementById('server-panel').classList.remove('open');
    document.getElementById('panel-overlay').classList.remove('show');
    document.body.style.overflow = '';
    _panelGuildId = null;
  }

  function switchTab(tab) {
    document.querySelectorAll('.sp-tab').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
    document.querySelectorAll('.sp-pane').forEach(p => p.classList.toggle('active', p.id === 'tab-' + tab));
  }

  async function loadGuildConfig(guildId) {
    if (_configCache[guildId]) { renderConfig(_configCache[guildId]); return; }
    document.getElementById('commands-list').innerHTML = '<div class="sp-loading">Loading…</div>';
    try {
      const r = await fetch(`/api/guilds/${guildId}/config`);
      const cfg = await r.json();
      _configCache[guildId] = cfg;
      renderConfig(cfg);
      
      // Load dynamic lists
      if (_panelHasBot) {
        loadAutoResponders();
        loadStickyMessages();
        loadButtonRoles();
        loadBannedWords();
        loadShopItems();
      }
    } catch (e) {
      document.getElementById('commands-list').innerHTML = '<div style="color:#ff6b6b">Failed to load configuration.</div>';
    }
  }

  function renderConfig(cfg) {
    _disabled = new Set(cfg.disabled || []);

    // ---- Commands ----
    const noBot = document.getElementById('cmd-no-bot');
    const saveBtn = document.getElementById('cmd-save-btn');
    noBot.style.display = _panelHasBot ? 'none' : 'block';
    saveBtn.style.display = _panelHasBot ? 'block' : 'none';

    document.getElementById('cmd-prefix').value = cfg.prefix || '!';
    document.getElementById('cmd-prefix').disabled = !_panelHasBot;

    const categories = {};
    (cfg.commands || []).forEach(cmd => {
      if (!categories[cmd.category]) categories[cmd.category] = [];
      categories[cmd.category].push(cmd);
    });

    const catIcons = { Moderation:'🛡️', Economy:'💰', Admin:'⚙️', Utility:'🔧' };
    let html = '';
    for (const [cat, cmds] of Object.entries(categories)) {
      html += `<div class="cmd-category"><div class="cmd-cat-label">${catIcons[cat]||'📦'} ${cat}</div>`;
      cmds.forEach(cmd => {
        const on = !_disabled.has(cmd.name);
        const dis = _panelHasBot ? '' : 'disabled';
        html += `<div class="cmd-row">
          <div class="cmd-info">
            <span class="cmd-name">/${cmd.name}</span>
            <span class="cmd-desc">${cmd.description}</span>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" class="cmd-toggle" data-cmd="${cmd.name}" ${on?'checked':''} ${dis}>
            <span class="toggle-track"></span>
          </label>
        </div>`;
      });
      html += '</div>';
    }
    document.getElementById('commands-list').innerHTML = html || '<p style="color:var(--text-muted)">No commands found.</p>';

    // ---- Auto Mod ----
    document.getElementById('am-no-bot').style.display  = _panelHasBot ? 'none' : 'block';
    document.getElementById('am-toggle').checked        = cfg.automod?.enabled || false;
    document.getElementById('am-toggle').disabled       = !_panelHasBot;
    document.getElementById('am-log').value             = cfg.automod?.logChannelId || '';
    document.getElementById('am-log').disabled          = !_panelHasBot;

    // ---- Verification ----
    document.getElementById('vf-no-bot').style.display  = _panelHasBot ? 'none' : 'block';
    document.getElementById('vf-channel').value         = cfg.verification?.channelId || '';
    document.getElementById('vf-role').value            = cfg.verification?.roleId    || '';
    document.getElementById('vf-channel').disabled      = !_panelHasBot;
    document.getElementById('vf-role').disabled         = !_panelHasBot;

    // ---- Welcome ----
    document.getElementById('wel-no-bot').style.display = _panelHasBot ? 'none' : 'block';
    document.getElementById('wel-channel').value        = cfg.welcome?.welcomeChannelId || '';
    document.getElementById('wel-msg').value            = cfg.welcome?.welcomeMessage   || '';
    document.getElementById('leave-channel').value      = cfg.welcome?.leaveChannelId   || '';
    document.getElementById('leave-msg').value          = cfg.welcome?.leaveMessage     || '';
    ['wel-channel','wel-msg','leave-channel','leave-msg'].forEach(id => document.getElementById(id).disabled = !_panelHasBot);

    // ---- Leveling ----
    document.getElementById('lvl-no-bot').style.display = _panelHasBot ? 'none' : 'block';
    document.getElementById('lvl-toggle').checked       = cfg.leveling?.enabled || false;
    document.getElementById('lvl-channel').value        = cfg.leveling?.levelUpChannelId || '';
    document.getElementById('lvl-toggle').disabled      = !_panelHasBot;
    document.getElementById('lvl-channel').disabled     = !_panelHasBot;

    // ---- Tickets ----
    document.getElementById('tkt-no-bot').style.display = _panelHasBot ? 'none' : 'block';
    document.getElementById('tkt-cat').value            = cfg.tickets?.categoryId || '';
    document.getElementById('tkt-role').value           = cfg.tickets?.supportRoleId || '';
